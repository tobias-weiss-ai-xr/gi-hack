# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# AI Provider (OpenAI)
OPENAI_API_KEY=sk-your-key-here

# Optional: Local LLM (used by ContactFinder — Ollama, LocalAI, vLLM, etc.)
LLM_ENDPOINT=http://localhost:11434/v1/chat/completions
LLM_MODEL=llama3

# Optional: Alternative AI Providers
# ANTHROPIC_API_KEY=sk-ant-...

# Tier 1 Adapter API Keys
# MFDS (South Korea): https://www.data.go.kr/ — free API key, 1M requests/day
# NMPA (China): https://udi.nmpa.gov.cn — free API key registration

# MFDS_API_KEY=your-korean-openapi-key
# NMPA_API_KEY=your-chinese-nmpa-key

# Server
PORT=3001
NODE_ENV=development
